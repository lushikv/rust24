{
  "name": "rust24",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/next-wasm.mjs dev",
    "build": "node scripts/next-wasm.mjs build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --conditions react-server --import tsx --test tests/unit/*.test.ts",
    "test:watch": "node --conditions react-server --import tsx --watch --test tests/unit/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "ioredis": "^5.10.1",
    "next": "16.2.6",
    "next-intl": "4.12.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/swc-wasm-nodejs": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "4.1.7",
    "@types/node": "22.15.17",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "eslint": "9.27.0",
    "eslint-config-next": "16.2.6",
    "prisma": "6.19.3",
    "tailwindcss": "4.1.7",
    "tsx": "^4.22.0",
    "typescript": "5.8.3",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  }
}
